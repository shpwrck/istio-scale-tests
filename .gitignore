# Private key and certificate material (beyond /cacerts/)
*.pem
*.key
*.crt

# Kubeconfig files (but not chart directories containing "kubeconfig" in the name)
kubeconfig
*kubeconfig*
!charts/*kubeconfig*/
!charts/*kubeconfig*/**

# Environment files with potential secrets
.env
.env.local
.env.*.local

# Propagation test results (TSV data and scraped metrics)
/propagation-test/results/

# Control-plane test results
/controlplane-test/results/

# Data-plane latency test results
/dataplane-test/results/

# Churn convergence test results
/churn-test/results/

# Terraform — state, workspace data, local plugins (keep **/.terraform.lock.hcl tracked)
/terraform/**/.terraform/
/terraform/**/*.tfstate
/terraform/**/*.tfstate.*
/terraform/**/.terraform.tfstate.lock.info
/terraform/**/terraform.tfstate.d/
/terraform/**/*.tfplan
/terraform/**/crash.log
/terraform/**/crash.*.log
/terraform/**/terraform.tfvars
