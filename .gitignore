# Generated certificates and local PEM material (see istio-setup/002-ossm-mc-cacerts.sh)
/cacerts/

# Local or environment-specific manifests (keep repo templates elsewhere if needed)
/manifests/

# Optional local cache (e.g. tooling clones)
/.cache/

# Git worktrees (isolated checkouts; see using-git-worktrees skill)
/.worktrees/

# Terraform — state, workspace data, local plugins (keep **/.terraform.lock.hcl tracked)
/terraform/**/.terraform/
/terraform/**/*.tfstate
/terraform/**/*.tfstate.*
/terraform/**/.terraform.tfstate.lock.info
/terraform/**/terraform.tfstate.d/
/terraform/**/*.tfplan
/terraform/**/crash.log
/terraform/**/crash.*.log
/terraform/**/terraform.tfvars

# Generated kubeconfig (contains cluster-admin credentials)
/terraform/rosa-hcp/*.kubeconfig
/terraform/rosa-hcp/rosa-generated.kubeconfig
