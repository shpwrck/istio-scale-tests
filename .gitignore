#VSCode settings
settings.json

# Private key and certificate material (beyond /cacerts/)
*.pem
*.key
*.crt

# Generated kubeconfig (terraform/rosa-hcp/kubeconfig)
/terraform/rosa-hcp/kubeconfig

# Environment files with potential secrets
.env
.env.local
.env.*.local

# Reviewer-loop tooling (playwright headless smoke tests)
/node_modules/
/package-lock.json

# Test results (TSV data, scraped metrics, reports)
/tests/propagation/results/
/tests/controlplane/results/
/tests/dataplane/results/
/tests/churn/results/
/tests/churn-dataplane/results/

# Terraform — state, workspace data, local plugins (keep **/.terraform.lock.hcl tracked)
/terraform/**/.terraform/
/terraform/**/*.tfstate
/terraform/**/*.tfstate.*
/terraform/**/.terraform.tfstate.lock.info
/terraform/**/terraform.tfstate.d/
/terraform/**/*.tfplan
/terraform/**/crash.log
/terraform/**/crash.*.log
/terraform/**/*.tfvars
!/terraform/**/*.tfvars.example
