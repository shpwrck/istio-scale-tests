# Isotope converter output (istio-multicluster/gen — see isotope-multicluster/README.md)
/isotope-multicluster/gen/

# Terraform-driven isotope topology (see isotope-multicluster/001-generate-topology-from-terraform.sh)
/isotope-multicluster/topology/generated-from-terraform.yaml

# Private key and certificate material (beyond /cacerts/)
*.pem
*.key
*.crt

# Kubeconfig files
kubeconfig
*kubeconfig*

# Environment files with potential secrets
.env
.env.local
.env.*.local

# Propagation test results (TSV data and scraped metrics)
/propagation-test/results/

# Terraform — state, workspace data, local plugins (keep **/.terraform.lock.hcl tracked)
/terraform/**/.terraform/
/terraform/**/*.tfstate
/terraform/**/*.tfstate.*
/terraform/**/.terraform.tfstate.lock.info
/terraform/**/terraform.tfstate.d/
/terraform/**/*.tfplan
/terraform/**/crash.log
/terraform/**/crash.*.log
/terraform/**/terraform.tfvars
