# Pinned platform and mesh versions — keep aligned with AGENTS.md.
# Source of truth for procedures: Red Hat OSSM 3.3 — Multi-cluster topologies:
# https://docs.redhat.com/en/documentation/red_hat_openshift_service_mesh/3.3/html/installing/ossm-multi-cluster-topologies
#
# shellcheck shell=bash
export OSSM_DOC_MULTI_CLUSTER_URL="${OSSM_DOC_MULTI_CLUSTER_URL:-https://docs.redhat.com/en/documentation/red_hat_openshift_service_mesh/3.3/html/installing/ossm-multi-cluster-topologies}"
export OPENSHIFT_VERSION="${OPENSHIFT_VERSION:-4.21.11}"
export KUBERNETES_VERSION="${KUBERNETES_VERSION:-v1.34.6}"
# Red Hat Advanced Cluster Management hub operator — channel must match a RHACM minor train supported for this OpenShift (see RHACM support matrix).
# Default pairs ACM 2.16 with OpenShift 4.21.x (hub cluster).
export ACM_CHANNEL="${ACM_CHANNEL:-release-2.16}"
export ACM_NAMESPACE="${ACM_NAMESPACE:-open-cluster-management}"
# Optional: Helm release names for platform-setup/001-acm-install-hub.sh (see platform-setup/001-acm-install-hub.sh --help).
# export ACM_OPERATOR_RELEASE="acm-operator"
# export ACM_MULTICLUSTER_HUB_RELEASE="acm-multicluster-hub"
# export ACM_KLUSTERLET_CONFIG_RELEASE="acm-klusterlet-config"
# Per-spoke Helm releases: ${ACM_MANAGED_CLUSTER_RELEASE_PREFIX}-<terraform-key> (default prefix acm-managed-cluster).
# export ACM_MANAGED_CLUSTER_RELEASE_PREFIX="acm-managed-cluster"
# export ACM_IMPORT_WAIT_SEC="900"
# export ACM_IMPORT_APPLY_RETRY_SEC="900"
# export ACM_CRDS_YAML_WAIT_SEC="180"
# export ACM_WAIT_MANAGED_CLUSTER_READY="1"
# export ACM_MANAGED_CLUSTER_READY_WAIT_SEC="3600"
# ManagedClusterSet name + spoke label value cluster.open-cluster-management.io/clusterset (platform-setup/001 Helm); must match acm-openshift-gitops-resources clusterSet / Placement.clusterSets (default istio-scale-tests).
export ACM_CLUSTER_SET="${ACM_CLUSTER_SET:-istio-scale-tests}"
# OpenShift GitOps operator (hub) — platform-setup/002-acm-openshift-gitops.sh; channel must match OpenShift/GitOps train.
export GITOPS_NAMESPACE="${GITOPS_NAMESPACE:-openshift-gitops}"
# Argo CD custom resource name on the hub (OpenShift GitOps default instance).
export GITOPS_ARGOCD_CR_NAME="${GITOPS_ARGOCD_CR_NAME:-openshift-gitops}"
# RHACM GitOps doc "ApplicationSet in any namespace": patch ArgoCD applicationSet env + ClusterRole/Binding (platform-setup/002). Set to 0/false to skip that block only.
export GITOPS_RHACM_APPSET_ANY_NAMESPACE="${GITOPS_RHACM_APPSET_ANY_NAMESPACE:-1}"
# OpenShift GitOps: merge these into ArgoCD.spec.applicationSet.sourceNamespaces (platform-setup/002). Wildcards are not supported — list each namespace (comma-separated). Default chart layout puts ApplicationSet in openshift-gitops (no extra allowlist needed); add namespaces here only if you install ApplicationSets outside the operand namespace.
export GITOPS_APPLICATION_SET_SOURCE_NAMESPACES="${GITOPS_APPLICATION_SET_SOURCE_NAMESPACES:-open-cluster-management-global-set}"
export GITOPS_OPERATOR_NAMESPACE="${GITOPS_OPERATOR_NAMESPACE:-openshift-operators}"
export GITOPS_OPERATOR_CHANNEL="${GITOPS_OPERATOR_CHANNEL:-gitops-1.14}"
# export GITOPS_PLACEMENT_NAME="acm-openshift-gitops-placement"
# export GITOPS_CLUSTER_CR_NAME="acm-openshift-gitops"
# When 1 (default in 002), Argo syncs charts/acm-openshift-gitops-resources (Application hub-acm-openshift-gitops-resources) and 002 patches Helm parameters; set 0 to install that chart with Helm from 002 only.
# export GITOPS_ACM_RESOURCES_VIA_ARGO="1"
# export HUB_ACM_GITOPS_APP_WAIT_SEC="600"
# export GITOPS_ADDON_ENABLED="true"
# export GITOPS_RESOURCES_RELEASE="acm-openshift-gitops-resources"
# Optional: only if you customize ApplicationSet to sync Git (public repo or Argo repo credential); default sample uses public Helm chart.
# export GITOPS_SAMPLE_REPO_URL="https://github.com/ORG/istio-scale-tests.git"
# export GITOPS_SAMPLE_REPO_REVISION="main"
# Git URL Argo CD clones for hub app-of-apps + cert-manager Applications (platform-setup/002). Example: git remote get-url origin
# export GITOPS_APP_REPO_URL="https://github.com/ORG/istio-scale-tests.git"
# export GITOPS_APP_REPO_REVISION="main"
# Private repo (optional): 002 creates an Argo CD repository Secret in GITOPS_NAMESPACE — never commit tokens (use env or token file).
# export GITOPS_APP_REPO_USERNAME="git"
# export GITOPS_APP_REPO_TOKEN_FILE="${HOME}/.secrets/gh_pat"
# Example placeholder file (copy outside git, replace line with real token): config/gitops-repo-token.example
# export GITOPS_APP_REPO_SSH_PRIVATE_KEY_FILE="${HOME}/.ssh/id_ed25519"
# export GITOPS_APP_REPO_PREFER_SSH="1"
# export GITOPS_APP_REPO_CREDENTIALS_SECRET_NAME="gitops-hub-app-repo"
# export GITOPS_HUB_APP_OF_APPS_RELEASE="gitops-hub-app-of-apps"
# export ARGOCD_STABILIZE_WAIT_SEC="900"
# MultiClusterHub spec.localClusterName (optional; 001 defaults from terraform first_cluster.cluster_name).
# export ACM_LOCAL_CLUSTER_NAME="rosa-001"
export ISTIO_VERSION="${ISTIO_VERSION:-v1.28.5}"
# Istio Helm chart istio/gateway version (no leading v); defaults from ISTIO_VERSION.
export ISTIO_GATEWAY_CHART_VERSION="${ISTIO_GATEWAY_CHART_VERSION:-${ISTIO_VERSION#v}}"
export ISTIO_HELM_REPO_URL="${ISTIO_HELM_REPO_URL:-https://istio-release.storage.googleapis.com/charts}"
# istio/gateway Helm value: use "openshift" so the chart omits sysctl + fixed UID incompatible with SCC.
export INGRESS_GATEWAY_PLATFORM="${INGRESS_GATEWAY_PLATFORM:-openshift}"
# Optional (AWS / ROSA NLB): attach security groups to the istio-ingressgateway LoadBalancer Service.
# Comma-separated SG IDs (multiple IDs are OK). Setup script escapes commas for Helm --set-string.
# SGs are VPC-scoped — for multiple clusters in different VPCs use either:
#   - config/ingress-lb-security-groups.map (see ingress-lb-security-groups.map.example), or
#   - per-context env vars: AWS_LOAD_BALANCER_SECURITY_GROUPS_<CONTEXT_SUFFIX> and
#     AWS_LOAD_BALANCER_EXTRA_SECURITY_GROUPS_<CONTEXT_SUFFIX> where CONTEXT_SUFFIX is the
#     context name uppercased with / : - replaced by _ (e.g. rosa-001 → ROSA_001).
# Globals below apply when no per-context map row / env overrides that field.
# export AWS_LOAD_BALANCER_SECURITY_GROUPS="sg-aaaaaaaaaaaaaaaaa"
# export AWS_LOAD_BALANCER_EXTRA_SECURITY_GROUPS="sg-bbbbbbbbbbbbbbbbb"
export MESH_ID="${MESH_ID:-mesh1}"
export NETWORK_SUFFIX="${NETWORK_SUFFIX:-network}"
# Mesh-wide Envoy access logs (istio.cluster.yaml.tpl → meshConfig).
export ACCESS_LOG_FILE="${ACCESS_LOG_FILE:-/dev/stdout}"
export ACCESS_LOG_ENCODING="${ACCESS_LOG_ENCODING:-JSON}"
# Default kube/oc contexts for setup scripts that accept --contexts (comma-separated).
export SETUP_CONTEXTS="${SETUP_CONTEXTS:-rosa-001,rosa-002,rosa-003}"
# Propagation test configuration (propagation-test/*.sh).
export PROPAGATION_TEST_NAMESPACE="${PROPAGATION_TEST_NAMESPACE:-propagation-test}"
export PROPAGATION_POLL_INTERVAL_MS="${PROPAGATION_POLL_INTERVAL_MS:-250}"
export PROPAGATION_TIMEOUT_SEC="${PROPAGATION_TIMEOUT_SEC:-120}"
export PROPAGATION_ITERATIONS="${PROPAGATION_ITERATIONS:-10}"
export PROPAGATION_PAUSE_SEC="${PROPAGATION_PAUSE_SEC:-30}"
