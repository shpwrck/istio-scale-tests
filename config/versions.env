# Pinned versions and core settings for istio-scale-tests.
# Operational defaults (namespaces, logging, test params) are in options.env.
#
# shellcheck shell=bash

# === Version Pins ===
export OPENSHIFT_VERSION="${OPENSHIFT_VERSION:-4.21.11}"
export KUBERNETES_VERSION="${KUBERNETES_VERSION:-v1.34.6}"
export ISTIO_VERSION="${ISTIO_VERSION:-v1.28.5}"
export ACM_CHANNEL="${ACM_CHANNEL:-release-2.16}"
# Concrete ACM/MCE CSV pin (BLOCKER #1 GO gate). The floating channel above resolves
# to "whatever is latest in the channel", so two installs can land on different MCE
# builds — and MCE's clusterview/UserPermission OpenAPI validity (the ArgoCD↔ACM
# crash, STRESS_TEST_STATUS.md BLOCKER #1) is version-specific. To pin a specific
# build, set ACM_MCE_VERSION to the operator CSV (e.g. "advanced-cluster-management.v2.16.3")
# of an ACM whose MCE serves valid clusterview OpenAPI; the Subscription then carries
# startingCSV + installPlanApproval=Manual so OLM cannot float past the asserted CSV.
# Empty (default) = float on the channel with Automatic approval (legacy behaviour).
export ACM_MCE_VERSION="${ACM_MCE_VERSION:-}"
export GITOPS_OPERATOR_CHANNEL="${GITOPS_OPERATOR_CHANNEL:-gitops-1.20}"
# Keep tests/dataplane/chart/values.yaml image.tag in sync with FORTIO_VERSION.
export FORTIO_VERSION="${FORTIO_VERSION:-1.69.5}"
export BUSYBOX_VERSION="${BUSYBOX_VERSION:-1.37.0}"
# Pre-warmed propagation backer image (O1). Keep tests/propagation/chart/values.yaml
# backer.image.tag in sync with HTTP_ECHO_VERSION. NOTE: hashicorp/http-echo uses a
# bare "1.0" tag (verified pullable; many http-echo forks use 0.2.x / 1.0.0 instead),
# so do not "normalize" this to 1.0.0 without re-checking the registry.
export HTTP_ECHO_VERSION="${HTTP_ECHO_VERSION:-1.0}"

# === Mesh Identity ===
export MESH_ID="${MESH_ID:-mesh1}"
export ACM_CLUSTER_SET="${ACM_CLUSTER_SET:-istio-scale-tests}"

# === Cluster Contexts ===
# Comma-separated kube contexts used by setup and test scripts.
export SETUP_CONTEXTS="${SETUP_CONTEXTS:-cluster-001,cluster-002,cluster-003}"

# Load operator and test defaults.
# shellcheck source=options.env
source "${BASH_SOURCE[0]%/*}/options.env"
