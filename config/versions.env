# Pinned platform and mesh versions — keep aligned with AGENTS.md.
# Source of truth for procedures: Red Hat OSSM 3.3 — Multi-cluster topologies:
# https://docs.redhat.com/en/documentation/red_hat_openshift_service_mesh/3.3/html/installing/ossm-multi-cluster-topologies
#
# shellcheck shell=bash
export OSSM_DOC_MULTI_CLUSTER_URL="${OSSM_DOC_MULTI_CLUSTER_URL:-https://docs.redhat.com/en/documentation/red_hat_openshift_service_mesh/3.3/html/installing/ossm-multi-cluster-topologies}"
export OPENSHIFT_VERSION="${OPENSHIFT_VERSION:-4.18.38}"
export KUBERNETES_VERSION="${KUBERNETES_VERSION:-v1.31.14}"
export ISTIO_VERSION="${ISTIO_VERSION:-v1.28.5}"
# Istio Helm chart istio/gateway version (no leading v); defaults from ISTIO_VERSION.
export ISTIO_GATEWAY_CHART_VERSION="${ISTIO_GATEWAY_CHART_VERSION:-${ISTIO_VERSION#v}}"
export ISTIO_HELM_REPO_URL="${ISTIO_HELM_REPO_URL:-https://istio-release.storage.googleapis.com/charts}"
# istio/gateway Helm value: use "openshift" so the chart omits sysctl + fixed UID incompatible with SCC.
export INGRESS_GATEWAY_PLATFORM="${INGRESS_GATEWAY_PLATFORM:-openshift}"
# Optional (AWS / ROSA NLB): attach security groups to the istio-ingressgateway LoadBalancer Service.
# Comma-separated SG IDs (multiple IDs are OK). Setup script escapes commas for Helm --set-string.
# SGs are VPC-scoped — for multiple clusters in different VPCs use either:
#   - config/ingress-lb-security-groups.map (see ingress-lb-security-groups.map.example), or
#   - per-context env vars: AWS_LOAD_BALANCER_SECURITY_GROUPS_<CONTEXT_SUFFIX> and
#     AWS_LOAD_BALANCER_EXTRA_SECURITY_GROUPS_<CONTEXT_SUFFIX> where CONTEXT_SUFFIX is the
#     context name uppercased with / : - replaced by _ (e.g. rosa-001 → ROSA_001).
# Globals below apply when no per-context map row / env overrides that field.
# export AWS_LOAD_BALANCER_SECURITY_GROUPS="sg-aaaaaaaaaaaaaaaaa"
# export AWS_LOAD_BALANCER_EXTRA_SECURITY_GROUPS="sg-bbbbbbbbbbbbbbbbb"
export MESH_ID="${MESH_ID:-mesh1}"
export NETWORK_SUFFIX="${NETWORK_SUFFIX:-network}"
# Mesh-wide Envoy access logs (istio.cluster.yaml.tpl → meshConfig).
export ACCESS_LOG_FILE="${ACCESS_LOG_FILE:-/dev/stdout}"
export ACCESS_LOG_ENCODING="${ACCESS_LOG_ENCODING:-JSON}"
# Default kube/oc contexts for setup scripts that accept --contexts (comma-separated).
export SETUP_CONTEXTS="${SETUP_CONTEXTS:-rosa-001,rosa-002,rosa-003}"
