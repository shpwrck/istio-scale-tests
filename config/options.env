# Operational defaults for istio-scale-tests.
# Most users won't need to change these. Sourced automatically by versions.env.
#
# Terraform users: ACM/GitOps variables below are mirrored in
# terraform/platform/variables.tf — set them via terraform.tfvars instead.
#
# shellcheck shell=bash

# === ACM Operator ===
export ACM_NAMESPACE="${ACM_NAMESPACE:-open-cluster-management}"

# === OpenShift GitOps ===
export GITOPS_NAMESPACE="${GITOPS_NAMESPACE:-openshift-gitops}"
export GITOPS_ARGOCD_CR_NAME="${GITOPS_ARGOCD_CR_NAME:-openshift-gitops}"
export GITOPS_OPERATOR_NAMESPACE="${GITOPS_OPERATOR_NAMESPACE:-openshift-operators}"
export GITOPS_RHACM_APPSET_ANY_NAMESPACE="${GITOPS_RHACM_APPSET_ANY_NAMESPACE:-1}"
export GITOPS_APPLICATION_SET_SOURCE_NAMESPACES="${GITOPS_APPLICATION_SET_SOURCE_NAMESPACES:-open-cluster-management-global-set}"

# === Mesh Defaults ===
# These mirror Helm chart defaults in charts/spoke-ossm/values.yaml.
export NETWORK_SUFFIX="${NETWORK_SUFFIX:-network}"
export ACCESS_LOG_FILE="${ACCESS_LOG_FILE:-/dev/stdout}"
export ACCESS_LOG_ENCODING="${ACCESS_LOG_ENCODING:-JSON}"

# === istiod /metrics scrape timeout (shared base) ===
# ONE place to tune the curl --max-time for every istiod /metrics scrape. The
# single (non-fanout) scrapes in tests/lib/metrics.sh and tests/lib/preamble.sh
# read this directly; the per-suite knobs below (FANOUT_METRICS_TIMEOUT,
# PROPAGATION_METRICS_TIMEOUT) DEFAULT FROM it so an operator can raise them all
# at once here, or override a single suite individually.
#
# DEFAULT RAISED 5 -> 30 (loud, deliberate): at 10k services the istiod /metrics
# body is MB-class and a 5s curl times out over a port-forward, so the single
# scrape was being SILENTLY DROPPED (preamble degraded to a missing reading;
# metrics.sh returned failure with no signal). 30s is comfortably above the
# observed MB-body fetch time at scale and still bounds a genuinely dead
# port-forward. Small-scale runs finish in well under 5s, so the larger ceiling
# does not change their behaviour or timing — it only stops the scale-run drop.
# Raising this far above 30 trades a slower dead-port-forward signal for more
# headroom: the single-scrape body fetches (metrics.sh / preamble.sh / the
# controlplane 002 primary + peak-poll scrapes) have no readiness pre-check, so a
# truly dead PF only surfaces after the full --max-time elapses on each attempt.
export METRICS_SCRAPE_TIMEOUT="${METRICS_SCRAPE_TIMEOUT:-30}"

# === AWS / Infrastructure (optional) ===
# Attach security groups to the istio-ingressgateway NLB Service.
# For per-cluster overrides, see config/ingress-lb-security-groups.map.example.
# export AWS_LOAD_BALANCER_SECURITY_GROUPS="sg-aaaaaaaaaaaaaaaaa"

# === Propagation Test ===
export PROPAGATION_TEST_NAMESPACE="${PROPAGATION_TEST_NAMESPACE:-propagation-test}"
export PROPAGATION_POLL_INTERVAL_MS="${PROPAGATION_POLL_INTERVAL_MS:-250}"
export PROPAGATION_TIMEOUT_SEC="${PROPAGATION_TIMEOUT_SEC:-120}"
export PROPAGATION_ITERATIONS="${PROPAGATION_ITERATIONS:-10}"
# Settle gap (seconds) after each iteration's drain / between sweep mesh-size steps.
export PROPAGATION_SETTLE_SEC="${PROPAGATION_SETTLE_SEC:-5}"
# Curl --max-time for the propagation probe's istiod /metrics scrapes (seconds).
# Defaults from the shared METRICS_SCRAPE_TIMEOUT base (above); override here only
# to tune the propagation suite independently.
export PROPAGATION_METRICS_TIMEOUT="${PROPAGATION_METRICS_TIMEOUT:-${METRICS_SCRAPE_TIMEOUT:-30}}"
# Number of watcher pod replicas per cluster. Higher counts produce more
# connected proxies, enabling histogram quantile extraction (p50 >= 10, p99 >= 30).
export PROPAGATION_WATCHER_REPLICAS="${PROPAGATION_WATCHER_REPLICAS:-1}"
# Safety cap: refuse sweeps larger than this many total iterations (mesh_sizes × iterations).
export PROPAGATION_MAX_MATRIX="${PROPAGATION_MAX_MATRIX:-64}"

# === Control-Plane Resource Test ===
export CONTROLPLANE_TEST_NAMESPACE="${CONTROLPLANE_TEST_NAMESPACE:-controlplane-test}"
export CONTROLPLANE_SERVICE_COUNT="${CONTROLPLANE_SERVICE_COUNT:-10}"
export CONTROLPLANE_REPLICAS_PER_SERVICE="${CONTROLPLANE_REPLICAS_PER_SERVICE:-3}"
export CONTROLPLANE_NAMESPACE_COUNT="${CONTROLPLANE_NAMESPACE_COUNT:-1}"
# Sidecar CR scoping: none|namespace|explicit. Drives a chart-level
# `Sidecar` resource per workload namespace (namespace mode) or per Deployment
# (explicit mode). `none` is the worst-case baseline.
export CONTROLPLANE_SIDECAR_SCOPING="${CONTROLPLANE_SIDECAR_SCOPING:-none}"
# Random pods per cluster to exec /config_dump on for per-sidecar config size
# measurement. Set to 0 to disable sampling.
export CONTROLPLANE_CONFIG_DUMP_SAMPLES="${CONTROLPLANE_CONFIG_DUMP_SAMPLES:-3}"
# Safety cap on 003-run-sweep.sh's cross-product matrix size. Larger sweeps
# require --force-large-matrix on the CLI.
export CONTROLPLANE_MAX_MATRIX="${CONTROLPLANE_MAX_MATRIX:-64}"
# PL37 cleanup->setup cascade contract (mirrors the churn-dataplane COEXEC_*
# contract, CONTROLPLANE_-prefixed here).
# The controlplane sweep recreates the same namespace every combo: 005 deletes it,
# 003 loops cleanup -> next 001, and 001 server-side-applies the chart (which
# includes a kind: Namespace). At 10k the namespaces hold many sidecar-injected
# pods (slow teardown), so a 005 that exceeds its bound leaves the namespace
# Terminating and the next 001's apply collides with it -> deterministic
# SETUP_FAILED cascade (PL37). Bound for 005's own namespace-termination wait:
export CONTROLPLANE_NS_DELETE_TIMEOUT_SEC="${CONTROLPLANE_NS_DELETE_TIMEOUT_SEC:-300}"
# 001 pre-apply wait (bounded PL4 poll-until-gone) for any pre-existing
# (Terminating) namespace to fully disappear on EVERY context before applying the
# chart's kind: Namespace. Same contract as the delete bound, so an operator
# override applies to both. A wait that EXHAUSTS dies -> 003's existing PL32
# SETUP_FAILED wrap records the row (not a hang, not a swallowed warning).
export CONTROLPLANE_SETUP_NS_WAIT_SEC="${CONTROLPLANE_SETUP_NS_WAIT_SEC:-${CONTROLPLANE_NS_DELETE_TIMEOUT_SEC}}"

# === Data-Plane Latency Test ===
export DATAPLANE_TEST_NAMESPACE="${DATAPLANE_TEST_NAMESPACE:-dataplane-test}"
export DATAPLANE_QPS_LEVELS="${DATAPLANE_QPS_LEVELS:-10,100,500,1000}"
export DATAPLANE_DURATION_SEC="${DATAPLANE_DURATION_SEC:-30}"
export DATAPLANE_NUM_CONNECTIONS="${DATAPLANE_NUM_CONNECTIONS:-8}"
export DATAPLANE_SETTLE_SEC="${DATAPLANE_SETTLE_SEC:-30}"
export DATAPLANE_MAX_MATRIX="${DATAPLANE_MAX_MATRIX:-64}"
export DATAPLANE_INTER_COMBO_SETTLE_SEC="${DATAPLANE_INTER_COMBO_SETTLE_SEC:-15}"
export DATAPLANE_WARMUP_DURATION_SEC="${DATAPLANE_WARMUP_DURATION_SEC:-5}"
export DATAPLANE_REPETITIONS="${DATAPLANE_REPETITIONS:-1}"

# === Churn / Convergence Test ===
export CHURN_TEST_NAMESPACE="${CHURN_TEST_NAMESPACE:-churn-test}"
export CHURN_DEPLOYMENT_COUNT="${CHURN_DEPLOYMENT_COUNT:-5}"
export CHURN_BASE_REPLICAS="${CHURN_BASE_REPLICAS:-1}"
export CHURN_SCALE_TO_REPLICAS="${CHURN_SCALE_TO_REPLICAS:-5}"
export CHURN_TIMEOUT_SEC="${CHURN_TIMEOUT_SEC:-120}"
export CHURN_POLL_INTERVAL_MS="${CHURN_POLL_INTERVAL_MS:-250}"
export CHURN_ITERATIONS="${CHURN_ITERATIONS:-5}"

# === Churn × Data-plane Co-execution Test ===
# Co-runs fortio (latency probe) and churn-target workloads in a SHARED
# namespace so we can attribute p99 latency deltas to churn (tests/churn-dataplane/).
export COEXEC_TEST_NAMESPACE="${COEXEC_TEST_NAMESPACE:-churn-dataplane-test}"
export COEXEC_BASELINE_DURATION_SEC="${COEXEC_BASELINE_DURATION_SEC:-60}"
export COEXEC_CHURN_DURATION_SEC="${COEXEC_CHURN_DURATION_SEC:-60}"
export COEXEC_CHURN_RATES="${COEXEC_CHURN_RATES:-1,5,10}"
export COEXEC_SETTLE_SEC="${COEXEC_SETTLE_SEC:-10}"
export COEXEC_INTER_COMBO_SETTLE_SEC="${COEXEC_INTER_COMBO_SETTLE_SEC:-15}"
export COEXEC_QPS="${COEXEC_QPS:-200}"
export COEXEC_NUM_CONNECTIONS="${COEXEC_NUM_CONNECTIONS:-8}"
export COEXEC_CHURN_SEED="${COEXEC_CHURN_SEED:-42}"
export COEXEC_REPETITIONS="${COEXEC_REPETITIONS:-1}"
export COEXEC_ISTIOD_PF_PORT="${COEXEC_ISTIOD_PF_PORT:-15014}"
# PL4 wait bound for 006's namespace deletion AND (by default) 001's pre-apply
# wait for a still-Terminating namespace. Raised 180 -> 240 with the
# cleanup-cascade fix: 006 now fast-drains sidecar pods before deleting the
# namespace, so the deletion is faster, but the bound stays generous as
# defense-in-depth for the worst-case 25-sidecar teardown.
export COEXEC_NS_DELETE_TIMEOUT_SEC="${COEXEC_NS_DELETE_TIMEOUT_SEC:-240}"
# 001 pre-apply wait for a pre-existing (Terminating) namespace to clear before
# applying the chart (which includes a kind: Namespace). Defaults to reuse the
# namespace-delete bound. (cleanup-cascade fix A)
export COEXEC_SETUP_NS_WAIT_SEC="${COEXEC_SETUP_NS_WAIT_SEC:-${COEXEC_NS_DELETE_TIMEOUT_SEC}}"
# 006 pod-delete grace period for the pre-delete fast-drain of sidecar-injected
# workloads, so istio-proxy drain doesn't dominate the namespace-delete window.
# Small but > 0 (0 would SIGKILL with no graceful proxy shutdown). (fix B)
export COEXEC_CLEANUP_GRACE_SEC="${COEXEC_CLEANUP_GRACE_SEC:-5}"
export COEXEC_SERVICE_PORT="${COEXEC_SERVICE_PORT:-8080}"

# === Tuning Profile Test ===
# Settle time (seconds) after applying/reverting a tuning profile before probing.
export TUNING_SETTLE_SEC="${TUNING_SETTLE_SEC:-60}"

# === Scale Coverage (O9) ===
# Phase 1 (legibility) is always on: every controlplane run surfaces achieved
# scale vs capacity from read-only kubectl gets. Phase 2 (capacity-derived
# sizing + a coverage floor) is DEFAULT-OFF — with SCALE_SIZING_MODE=fixed and
# SCALE_COVERAGE_ENFORCE=0 the harness behaviour is byte-identical to before O9.
#
# Workload sizing mode:
#   fixed - SERVICE_COUNT/REPLICAS come from the CLI/env as before (default).
#   auto  - controlplane 001 derives SERVICE_COUNT from cluster capacity
#           (cap_max_pods / replicas). Behind this flag only.
export SCALE_SIZING_MODE="${SCALE_SIZING_MODE:-fixed}"
# Fraction of post-reserve headroom to target (the explicit O9<->O8 throttle:
# bigger fraction = more pods = slower). Conservative default; calibrate live.
export SCALE_TARGET_FRACTION="${SCALE_TARGET_FRACTION:-0.7}"
# Fraction of node allocatable held back for kube-system / daemonsets / gateways
# and other non-workload overhead before sizing.
export SCALE_SYSTEM_RESERVE_FRACTION="${SCALE_SYSTEM_RESERVE_FRACTION:-0.15}"
# Minimum achieved-scale fraction (of capacity-derived max) below which a run is
# considered under-scaled. Informational unless SCALE_COVERAGE_ENFORCE=1.
export SCALE_COVERAGE_MIN_FRACTION="${SCALE_COVERAGE_MIN_FRACTION:-0.25}"
# Coverage-floor enforcement: 0 = warn only (default); 1 = hard-fail (non-zero
# exit) when achieved scale is under SCALE_COVERAGE_MIN_FRACTION.
export SCALE_COVERAGE_ENFORCE="${SCALE_COVERAGE_ENFORCE:-0}"
# Per-pod resource cost estimate used ONLY by SCALE_SIZING_MODE=auto sizing (the
# dummy app declares no requests; the dominant cost is the injected istio-proxy
# sidecar). Conservative defaults that under-provision rather than over-provision;
# calibrate against a real cluster on the clean re-run.
export SCALE_PER_POD_CPU_M="${SCALE_PER_POD_CPU_M:-200}"
export SCALE_PER_POD_MEM_MI="${SCALE_PER_POD_MEM_MI:-256}"
# Customer SLA verdict bands (read by tests/lib/envelope.sh:env_sla_verdict via the
# controlplane report). A utilization (% of cross-replica limit for istiod, % of node
# allocatable for workers) at/above FAIL -> FAIL; in [CAUTION,FAIL) -> CAUTION; below
# CAUTION -> PASS. Integrity gates (in-window istiod restart, zero valid samples) FAIL
# regardless. Tune per customer SLA; defaults are conservative observability bands.
export SCALE_SLA_CAUTION_PCT="${SCALE_SLA_CAUTION_PCT:-75}"
export SCALE_SLA_FAIL_PCT="${SCALE_SLA_FAIL_PCT:-90}"

# === Metrics-API reads (#44) ===
# The O9 utilization-% columns (istiod_*_pct_of_limit, node_*_pct) are sourced
# from `kubectl top` (the metrics API / metrics-server) — a path independent of
# istiod's own /metrics that the sweep measures. None of these guards ever aborts
# the run (utilization is observability, not the core measurement).
#
# ROOT CAUSE of the 2026-06-04 all-N/A run (investigated read-only, #44):
# metrics-server was healthy the whole time (up 46h, API Available throughout) and
# `kubectl get` worked — only `kubectl top` returned nothing. `top` goes through the
# aggregated metrics API, which is slower than etcd `get` (~1.8s idle baseline here,
# dominated by the OAuth exec-credential round-trip); under the sweep's concurrent
# 10-context load it exceeded the old hardcoded 5s timeout while `get` stayed under.
#
# Primary fix — a generous, dedicated timeout for the (slower) `top` reads; the etcd
# `get` reads keep their 5s (proven sufficient: they populated during that run).
export CAP_TOP_TIMEOUT="${CAP_TOP_TIMEOUT:-15}"               # seconds for kubectl top (vs 5s for get)
# Defense-in-depth — per-read retry rides through a BRIEF mid-sweep blip; reads run
# OUTSIDE the scrape window, so the latency is measurement-neutral. Worst-case extra
# latency per top read when metrics is persistently down ~= ATTEMPTS*(TIMEOUT+BACKOFF).
export CAP_TOP_ATTEMPTS="${CAP_TOP_ATTEMPTS:-2}"
export CAP_TOP_BACKOFF_S="${CAP_TOP_BACKOFF_S:-2}"
# Defense-in-depth — preflight gate (003): before the sweep loop, poll `top nodes`
# on every context until the metrics API serves data, bounded by this timeout.
# Records `# METRICS_API=available|unavailable:<ctxs>` in the TSV preamble and WARNs.
# Catches a genuine metrics-server-down-at-start (a DIFFERENT failure than the
# load-induced timeout above — it probes idle, so it would NOT have caught the
# 07:25Z run; the CAP_TOP_TIMEOUT bump is what addresses that).
export METRICS_READY_TIMEOUT="${METRICS_READY_TIMEOUT:-120}"   # seconds; 0 disables the gate
export METRICS_READY_INTERVAL="${METRICS_READY_INTERVAL:-10}"  # seconds between poll rounds
