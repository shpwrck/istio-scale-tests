# Copy to terraform.tfvars (gitignored) and adjust.
# Requires terraform/rosa-hcp/ to be applied first.

# --- Required ---

# Git repo URL for the Argo CD app-of-apps (hub Applications source).
# Without this, the mesh charts are not deployed.
gitops_app_repo_url = "https://github.com/shpwrck/istio-scale-tests.git"

# For private repos, set one of these (prefer TF_VAR_ env vars to avoid
# committing secrets):
# gitops_app_repo_password        = ""   # HTTPS PAT/token
# gitops_app_repo_ssh_private_key = ""   # SSH key (use SSH clone URL above)

# --- Incremental mesh ---

# Number of spokes that get Istio (0 = all, sorted order).
# mesh_member_count = 0

# --- ACM (defaults rarely need changing) ---

# acm_channel            = "release-2.16"
# acm_namespace          = "open-cluster-management"
# acm_cluster_set        = "istio-scale-tests"
# acm_local_cluster_name = null                       # auto from first cluster key

# --- OpenShift GitOps / Argo CD (defaults rarely need changing) ---

# gitops_operator_channel        = "gitops-1.14"
# gitops_namespace               = "openshift-gitops"
# gitops_argocd_cr_name          = "openshift-gitops"
# gitops_app_repo_revision       = "main"
