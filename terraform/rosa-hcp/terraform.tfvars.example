# Copy to terraform.tfvars (gitignored) and adjust.
# export RHCS_TOKEN='...'   # or set rhcs_token below (avoid committing secrets)

aws_region         = "us-east-2"
openshift_version  = "4.21.11"

# Optional: set false if your account cannot change service quotas via API.
# manage_service_quotas = false

common_tags = {
  environment = "scale-test"
}

# --- Generated clusters (same pattern as the former manual `clusters` map) ---
cluster_count = 3

# Terraform keys, OCM cluster_name, and kubectl/oc context names (first → rosa-001 …).
cluster_name_format = "rosa-%03d"

# VPC CIDRs: idx 0..cluster_count-1 uses format(idx + vpc_cidr_index_start).
# Defaults → 10.0.0.0/16, 10.1.0.0/16, 10.2.0.0/16
vpc_cidr_format      = "10.%d.0.0/16"
vpc_cidr_index_start = 0
cluster_index_start  = 1

# Optional shared overrides for every cluster:
# cluster_defaults = {
#   replicas                 = 2
#   compute_machine_type     = "m5.xlarge"
#   ec2_metadata_http_tokens = "required"
#   worker_autoscale_min       = 2
#   worker_autoscale_max       = 10
#   tags                       = {}
# }

# --- Platform setup (ACM + GitOps) ---
# Two-phase apply: first create clusters (default), then set to true and apply again.
# enable_platform_setup = true

# ACM hub configuration:
# acm_channel              = "release-2.16"
# acm_namespace            = "open-cluster-management"
# acm_cluster_set          = "istio-scale-tests"
# acm_local_cluster_name   = null       # auto from first cluster key
# acm_install_klusterletconfig = true

# OpenShift GitOps / Argo CD:
# enable_gitops                  = true
# gitops_namespace               = "openshift-gitops"
# gitops_operator_channel        = "gitops-1.14"
# gitops_argocd_cr_name          = "openshift-gitops"
# argocd_resource_limits_cpu     = "4"
# argocd_resource_limits_memory  = "4Gi"
# gitops_app_repo_url            = "https://github.com/ORG/istio-scale-tests.git"
# gitops_app_repo_revision       = "main"
# gitops_app_repo_username       = "git"          # default for PAT auth
# gitops_app_repo_password       = ""             # HTTPS PAT/token (sensitive; prefer TF_VAR_gitops_app_repo_password)
# gitops_app_repo_ssh_private_key = ""            # SSH key (sensitive; mutually exclusive with password)
# gitops_rhacm_appset_any_namespace = true
# gitops_applicationset_source_namespaces = ["open-cluster-management-global-set"]
# gitops_addon_enabled           = true

# Incremental mesh: number of spokes that get Istio (0 = all, sorted order).
# mesh_member_count = 0
