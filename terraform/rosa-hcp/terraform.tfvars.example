# Copy to terraform.tfvars (gitignored) and adjust.
# export RHCS_TOKEN='...'   # or set rhcs_token below (avoid committing secrets)

aws_region         = "us-east-2"
openshift_version  = "4.18.38"

# Optional: set false if your account cannot change service quotas via API.
# manage_service_quotas = false

# kubeconfig_output_path    = "/tmp/rosa.kubeconfig"
# kubeconfig_skip_tls_verify = true

common_tags = {
  environment = "scale-test"
}

clusters = {
  rosa-001 = {
    cluster_name = "scale-hcp-001"
    vpc_cidr     = "10.0.0.0/16"
  }
  rosa-002 = {
    cluster_name = "scale-hcp-002"
    vpc_cidr     = "10.1.0.0/16"
  }
  rosa-003 = {
    cluster_name = "scale-hcp-003"
    vpc_cidr     = "10.2.0.0/16"
    # replicas defaults to 2 (single-AZ ROSA minimum). Optional: replicas = 3
    # compute_machine_type = "m5.xlarge"
    # Default worker pool autoscaling: worker_autoscale_min = 2, worker_autoscale_max = 10
  }
}
