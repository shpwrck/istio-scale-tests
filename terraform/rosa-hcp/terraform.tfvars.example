# Copy to terraform.tfvars (gitignored) and adjust.
# export RHCS_TOKEN='...'   # or set rhcs_token below (avoid committing secrets)

aws_region         = "us-east-2"
openshift_version  = "4.21.11"

# Optional: set false if your account cannot change service quotas via API.
# manage_service_quotas = false

common_tags = {
  environment = "scale-test"
}

# --- Generated clusters (same pattern as the former manual `clusters` map) ---
cluster_count = 3

# Terraform keys, OCM cluster_name, and kubectl/oc context names (first → rosa-001 …).
cluster_name_format = "rosa-%03d"

# VPC CIDRs: idx 0..cluster_count-1 uses format(idx + vpc_cidr_index_start).
# Defaults → 10.0.0.0/16, 10.1.0.0/16, 10.2.0.0/16
vpc_cidr_format      = "10.%d.0.0/16"
vpc_cidr_index_start = 0
cluster_index_start  = 1

# Optional shared overrides for every cluster:
# cluster_defaults = {
#   replicas                 = 2
#   compute_machine_type     = "m5.xlarge"
#   ec2_metadata_http_tokens = "required"
#   worker_autoscale_min       = 2
#   worker_autoscale_max       = 10
#   tags                       = {}
# }
