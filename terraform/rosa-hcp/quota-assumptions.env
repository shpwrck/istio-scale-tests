# shellcheck shell=bash
# =============================================================================
# Inputs for helpers/rosa-hcp-aws-quotas.sh (plan mode only)
# =============================================================================
# Provenance: docs/quota-assumptions.source.md
#
# When terraform/rosa-hcp/main.tf bumps upstream  version = "X.Y.Z", open the same
# tag of https://github.com/terraform-redhat/terraform-rhcs-rosa-hcp and re-check
# every value below, then update docs/quota-assumptions.source.md.
#
# Keep UPSTREAM_MODULE_VERSION equal to both module blocks in main.tf.
UPSTREAM_MODULE_VERSION=1.7.3

# --- Structural (this repository) ---
# One VPC + one internet gateway + one OIDC stack per cluster — terraform/rosa-hcp/README.md,
# main.tf (module.vpc for_each, create_oidc = true).

# --- Derived from upstream rhcs//modules/vpc (same version as main.tf) ---
# NAT + EIP per VPC: aws_nat_gateway / aws_eip use count = length(availability_zones)
# https://github.com/terraform-redhat/terraform-rhcs-rosa-hcp/blob/v1.7.3/modules/vpc/main.tf
#
# Set to the maximum var.clusters[*].availability_zones_count you use (see variables.tf).
QUOTA_ASSUMED_AVAILABILITY_ZONES_COUNT=3

# Per cluster, each used AZ gets one NAT (quota “NAT gateways per Availability Zone” ~ N clusters).
QUOTA_ASSUMED_NAT_PER_AZ_PER_CLUSTER=1

# “Regional NAT gateways per VPC”: one VPC’s NAT count = AZs used (same submodule).
QUOTA_ASSUMED_NAT_PER_VPC="${QUOTA_ASSUMED_AVAILABILITY_ZONES_COUNT}"

# EIPs from VPC submodule only (NAT), per cluster.
QUOTA_ASSUMED_VPC_NAT_EIP_PER_CLUSTER="${QUOTA_ASSUMED_AVAILABILITY_ZONES_COUNT}"

# EIPs outside that submodule (e.g. load balancers / ROSA). Tune after measuring one cluster.
QUOTA_ASSUMED_EIP_EXTRA_PER_CLUSTER=5

QUOTA_ASSUMED_EIP_PER_CLUSTER=$((QUOTA_ASSUMED_VPC_NAT_EIP_PER_CLUSTER + QUOTA_ASSUMED_EIP_EXTRA_PER_CLUSTER))

# --- Not from VPC Terraform; validate when bumping OpenShift or rhcs module ---
# Order-of-magnitude for STS/account/operator roles. Prefer measuring one cluster:
#   aws iam list-roles --query 'length(Roles)' after install + divide by cluster count in account.
# Doc starting point: https://docs.aws.amazon.com/rosa/latest/userguide/welcome.html
QUOTA_ASSUMED_IAM_ROLES_PER_CLUSTER=50
